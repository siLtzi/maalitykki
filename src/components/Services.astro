---
---

<section class="services" id="palvelut">
	<div class="container">
		<div class="services__header" data-reveal="up">
			<div class="services__intro">
				<div class="services__overline">
					<span class="services__overline-line"></span>
					<span class="services__overline-text">Mitä teemme</span>
				</div>
				<h2 class="services__title">Palvelumme</h2>
			</div>
			<p class="services__desc">
				Olipa kyseessä omakotitalo, mökki tai muu kiinteistö,
				Maalitykki hoitaa homman tarkasti ja luotettavasti.
			</p>
		</div>

		<div class="services__grid" data-stagger>
			<!-- Ulkomaalaus -->
			<a href="#yhteystiedot" class="service-card">
				<div class="service-card__icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
				</div>
				<h3 class="service-card__title">Ulkomaalaus</h3>
				<p class="service-card__subtitle">Uutta ilmettä ja suojaa rakennuksellesi</p>
				<p class="service-card__desc">Maalaus ei ole pelkkää pintaa — se on tärkeä osa rakennuksen suojaa ja ulkonäköä. Tarjoamme ammattitaidolla tehdyt ulkomaalaukset, jotka kestävät aikaa ja pohjoisen vaihtelevia sääolosuhteita.</p>
				<p class="service-card__desc">Huolehdimme maalaustyön jokaisesta vaiheesta — alustan puhdistuksesta ja pohjatöistä aina viimeiseen siveltimenvetoon.</p>
				<span class="service-card__link">
					Pyydä tarjous
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
				</span>
			</a>

			<!-- Kattopinnoitus -->
			<a href="#yhteystiedot" class="service-card">
				<div class="service-card__icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
				</div>
				<h3 class="service-card__title">Kattopinnoitus</h3>
				<p class="service-card__subtitle">Suojaa ja siistiä ilmettä katollesi</p>
				<p class="service-card__desc">Kattosi kohtaa vuodesta toiseen vaihtelevat sääolosuhteet — aurinko, sade, lumi ja pakkanen kuluttavat sen pintaa. Kattopinnoituksella palautat katon suojaavat ominaisuudet ja parannat samalla koko rakennuksen ulkonäköä.</p>
				<p class="service-card__desc">Käytämme laadukkaita materiaaleja ja huolellista työjälkeä. Olipa kyse tiilikatosta tai muusta pinnoitettavasta materiaalista, meiltä saat toimivan ja kustannustehokkaan ratkaisun.</p>
				<span class="service-card__link">
					Pyydä tarjous
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
				</span>
			</a>
		</div>
	</div>
</section>

<style>
	.services {
		position: relative;
		z-index: 2;
		padding-top: var(--section-padding);
		padding-bottom: var(--section-padding);
		background: var(--color-bg-dark);
		color: var(--color-text-on-dark);
		box-shadow: 0 -20px 60px rgba(0, 0, 0, 0.25);
	}

	/* Header: title left, desc right */
	.services__header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 3rem;
		margin-bottom: 2.6rem;
		padding-bottom: 1.8rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
	}

	.services__intro {
		flex-shrink: 0;
	}

	.services__overline {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin-bottom: 1.25rem;
	}

	.services__overline-line {
		display: block;
		width: 2.5rem;
		height: 2px;
		background: var(--color-accent);
		border-radius: 1px;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 1.4s cubic-bezier(0.215, 0.61, 0.355, 1) 0.3s;
	}

	.services__header.revealed .services__overline-line {
		transform: scaleX(1);
	}

	.services__overline-text {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
	}

	.services__title {
		font-size: clamp(2rem, 4.5vw, 3.25rem);
		letter-spacing: -0.035em;
		font-weight: 800;
		line-height: 1.1;
	}

	.services__desc {
		max-width: 420px;
		font-size: 1rem;
		line-height: 1.75;
		color: rgba(255, 255, 255, 0.7);
	}

	/* Card grid */
	.services__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		padding: 3rem 2.5rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-left: 3px solid var(--color-accent);
		border-radius: 4px;
		transition: background 0.3s ease, border-color 0.3s ease, transform 0.25s ease;
		text-decoration: none;
		color: inherit;
	}

	.service-card:hover {
		background: rgba(255, 255, 255, 0.07);
		border-color: rgba(255, 255, 255, 0.18);
		border-left-color: var(--color-accent);
		transform: translateY(-3px);
	}

	.service-card__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		border-radius: 4px;
		background: rgba(182, 90, 53, 0.12);
		color: var(--color-accent);
		margin-bottom: 1.75rem;
	}

	.service-card__title {
		font-size: 1.4rem;
		font-weight: 700;
		margin-bottom: 0.35rem;
		letter-spacing: -0.01em;
	}

	.service-card__subtitle {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--color-accent);
		margin-bottom: 1.25rem;
	}

	.service-card__desc {
		font-size: 0.925rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.72);
	}

	.service-card__desc + .service-card__desc {
		margin-top: 0.75rem;
	}

	.service-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.5rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-accent);
		transition: gap 0.2s ease;
	}

	.service-card:hover .service-card__link {
		gap: 0.6rem;
	}

	.service-card__link svg {
		transition: transform 0.2s ease;
	}

	.service-card:hover .service-card__link svg {
		transform: translate(2px, -2px);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.services__header {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
		}

		.services__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.service-card {
			padding: 2.2rem 1.4rem;
		}
	}
</style>
