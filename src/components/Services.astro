---
---

<section class="services" id="palvelut">
	<div class="container">
		<div class="services__header" data-reveal="up">
			<div class="services__intro">
				<div class="services__overline">
					<span class="services__overline-line"></span>
					<span class="services__overline-text">Mitä teemme</span>
				</div>
				<h2 class="services__title">Palvelumme</h2>
			</div>
			<p class="services__desc">
				Olipa kyseessä omakotitalo, mökki tai muu kiinteistö,
				Maalitykki hoitaa homman tarkasti ja luotettavasti.
			</p>
		</div>

		<div class="services__grid" data-stagger>
			<!-- Ulkomaalaus -->
			<a href="#yhteystiedot" class="service-card">
				<div class="service-card__img-wrap">
					<img src="/maalaus.png" alt="Ulkomaalaustyö" class="service-card__img" />
				</div>
				<div class="service-card__body">
					<h3 class="service-card__title">Ulkomaalaus</h3>
					<p class="service-card__subtitle">Uutta ilmettä ja suojaa rakennuksellesi</p>
					<p class="service-card__desc">Maalaus ei ole pelkkää pintaa — se on tärkeä osa rakennuksen suojaa ja ulkonäköä. Tarjoamme ammattitaidolla tehdyt ulkomaalaukset, jotka kestävät aikaa ja pohjoisen vaihtelevia sääolosuhteita.</p>
					<p class="service-card__desc">Huolehdimme maalaustyön jokaisesta vaiheesta — alustan puhdistuksesta ja pohjatöistä aina viimeiseen siveltimenveto on.</p>
					<span class="service-card__link">
						Pyydä tarjous
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</span>
				</div>
			</a>

			<!-- Kattopinnoitus -->
			<a href="#yhteystiedot" class="service-card">
				<div class="service-card__img-wrap">
					<img src="/kattopinnoitus.png" alt="Kattopinnoitustyö" class="service-card__img" />
				</div>
				<div class="service-card__body">
					<h3 class="service-card__title">Kattopinnoitus</h3>
					<p class="service-card__subtitle">Suojaa ja siistiä ilmettä katollesi</p>
					<p class="service-card__desc">Kattosi kohtaa vuodesta toiseen vaihtelevat sääolosuhteet — aurinko, sade, lumi ja pakkanen kuluttavat sen pintaa. Kattopinnoituksella palautat katon suojaavat ominaisuudet ja parannat samalla koko rakennuksen ulkonäköä.</p>
					<p class="service-card__desc">Käytämme laadukkaita materiaaleja ja huolellista työjälkeä. Olipa kyse tiilikatosta tai muusta pinnoitettavasta materiaalista, meiltä saat toimivan ja kustannustehokkaan ratkaisun.</p>
					<span class="service-card__link">
						Pyydä tarjous
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</span>
				</div>
			</a>
		</div>
	</div>
</section>

<style>
	.services {
		position: relative;
		z-index: 2;
		padding-top: var(--section-padding);
		padding-bottom: var(--section-padding);
		background: var(--color-bg-dark);
		color: var(--color-text-on-dark);
		box-shadow: 0 -20px 60px rgba(0, 0, 0, 0.25);
	}

	/* Header: title left, desc right */
	.services__header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 3rem;
		margin-bottom: 2.6rem;
		padding-bottom: 1.8rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
	}

	.services__intro {
		flex-shrink: 0;
	}

	.services__overline {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin-bottom: 1.25rem;
	}

	.services__overline-line {
		display: block;
		width: 2.5rem;
		height: 2px;
		background: var(--color-accent);
		border-radius: 1px;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s;
	}

	.services__header.revealed .services__overline-line {
		transform: scaleX(1);
	}

	.services__overline-text {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-accent);
	}

	.services__title {
		font-size: clamp(2rem, 4.5vw, 3.25rem);
		letter-spacing: -0.035em;
		font-weight: 800;
		line-height: 1.1;
	}

	.services__desc {
		max-width: 420px;
		font-size: 1rem;
		line-height: 1.75;
		color: rgba(255, 255, 255, 0.7);
	}

	/* Card grid */
	.services__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 6px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
	}

	.service-card__img-wrap {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
	}

	.service-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.service-card:hover .service-card__img {
		transform: scale(1.04);
	}

	.service-card__body {
		padding: 2.25rem 2.5rem 2.5rem;
		display: flex;
		flex-direction: column;
		border-left: 3px solid var(--color-accent);
	}

	.service-card__title {
		font-size: 1.4rem;
		font-weight: 700;
		margin-bottom: 0.35rem;
		letter-spacing: -0.01em;
	}

	.service-card__subtitle {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--color-accent);
		margin-bottom: 1.25rem;
	}

	.service-card__desc {
		font-size: 0.925rem;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.72);
	}

	.service-card__desc + .service-card__desc {
		margin-top: 0.75rem;
	}

	.service-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.5rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-accent);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.services__header {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
		}

		.services__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.service-card__body {
			padding: 1.75rem 1.4rem 2rem;
		}
	}
</style>

<script>
	import gsap from 'gsap';

	document.querySelectorAll('.service-card').forEach((card) => {
		const link = card.querySelector('.service-card__link');
		const arrow = link?.querySelector('svg');

		card.addEventListener('mouseenter', () => {
			gsap.to(card, {
				y: -5,
				background: 'rgba(255, 255, 255, 0.07)',
				borderColor: 'rgba(255, 255, 255, 0.18)',
				duration: 0.25,
				ease: 'power3.out',
				overwrite: true,
			});
			if (link) gsap.to(link, { gap: '0.6rem', duration: 0.2, ease: 'power2.out' });
			if (arrow) gsap.to(arrow, { x: 2, y: -2, duration: 0.2, ease: 'power2.out' });
		});
		card.addEventListener('mouseleave', () => {
			gsap.to(card, {
				y: 0,
				background: 'rgba(255, 255, 255, 0.04)',
				borderColor: 'rgba(255, 255, 255, 0.1)',
				duration: 0.35,
				ease: 'power2.out',
				overwrite: true,
			});
			if (link) gsap.to(link, { gap: '0.35rem', duration: 0.25, ease: 'power2.out' });
			if (arrow) gsap.to(arrow, { x: 0, y: 0, duration: 0.25, ease: 'power2.out' });
		});
	});
</script>
