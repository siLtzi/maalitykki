---
const currentYear = new Date().getFullYear();

const services = [
	'Ulkomaalaus',
	'Kattopinnoitus',
];

const company = [
	{ label: 'Tietoa meistä', href: '#tietoa' },
	{ label: 'Työnäytteet', href: '#tyonaytteet' },
	{ label: 'Yhteystiedot', href: '#yhteystiedot' },
];
---

<footer class="footer" id="yhteystiedot">
	<div class="container">
		<div class="footer__grid" data-stagger>
			<!-- Brand column -->
			<div class="footer__brand">
				<a href="/" class="footer__logo">
					<img src="/maalitykki1.png" alt="Maalitykki" class="footer__logo-img" />
				</a>
				<p class="footer__description">
					Ulkomaalauksiin erikoistunut kotimainen yritys. Olipa kyseessä omakotitalo, mökki tai muu kiinteistö — Maalitykki hoitaa homman.
				</p>
				<div class="footer__social">
					<a href="#" aria-label="Facebook">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
					</a>
					<a href="#" aria-label="Instagram">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
					</a>
				</div>
			</div>

			<!-- Services column -->
			<div class="footer__column">
				<h3 class="footer__heading">Palvelut</h3>
				<ul class="footer__list">
					{services.map((s) => (
						<li><a href="#palvelut">{s}</a></li>
					))}
				</ul>
			</div>

			<!-- Company column -->
			<div class="footer__column">
				<h3 class="footer__heading">Yritys</h3>
				<ul class="footer__list">
					{company.map((item) => (
						<li><a href={item.href}>{item.label}</a></li>
					))}
				</ul>
			</div>

			<!-- Contact column -->
			<div class="footer__column">
				<h3 class="footer__heading">Ota yhteyttä</h3>
				<ul class="footer__list footer__contact">
					<li>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						<a href="tel:+358401234567">040 123 4567</a>
					</li>
					<li>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
						<a href="mailto:info@maalitykki.fi">info@maalitykki.fi</a>
					</li>
					<li>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
						<span>Oulu, Suomi</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="footer__bottom">
			<p>&copy; {currentYear} Maalitykki. Kaikki oikeudet pidätetään.</p>
			<p class="footer__legal">Y-tunnus: 1234567-8</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: var(--color-bg-dark);
		color: var(--color-text-on-dark);
		padding-top: var(--section-padding);
		padding-bottom: 2rem;
	}

	.footer__grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr 1.1fr;
		gap: 3.5rem;
		padding-bottom: 3rem;
	}

	.footer__logo {
		display: inline-block;
		margin-bottom: 1rem;
	}

	.footer__logo-img {
		height: 44px;
		width: auto;
		filter: brightness(0) invert(1);
	}

	.footer__description {
		font-size: 0.9rem;
		color: rgba(250, 249, 247, 0.62);
		line-height: 1.7;
		max-width: 300px;
		margin-bottom: 1.5rem;
	}

	.footer__social {
		display: flex;
		gap: 0.75rem;
	}

	.footer__social a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 4px;
		background: rgba(255, 255, 255, 0.06);
		color: rgba(250, 249, 247, 0.6);
		transition: background 0.2s ease, color 0.2s ease;
	}

	.footer__social a:hover {
		background: rgba(255, 255, 255, 0.12);
		color: white;
	}

	.footer__heading {
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(250, 249, 247, 0.4);
		margin-bottom: 1.25rem;
	}

	.footer__list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer__list a,
	.footer__list span {
		font-size: 0.9rem;
		color: rgba(250, 249, 247, 0.6);
		transition: color 0.2s ease;
	}

	.footer__list a:hover {
		color: white;
	}

	.footer__contact li {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.35rem 0;
	}

	.footer__contact svg {
		color: rgba(250, 249, 247, 0.35);
		flex-shrink: 0;
	}

	.footer__bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.3rem;
		font-size: 0.8125rem;
		color: rgba(250, 249, 247, 0.35);
	}

	.footer__legal {
		font-size: 0.8125rem;
	}

	@media (max-width: 900px) {
		.footer__grid {
			grid-template-columns: 1fr 1fr;
			gap: 2.5rem;
		}

		.footer__brand {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 520px) {
		.footer__grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.footer__description {
			max-width: 100%;
		}

		.footer__bottom {
			flex-direction: column;
			gap: 0.5rem;
			text-align: center;
		}
	}
</style>
