---

<section class="motto">
	<div class="container">
		<div class="motto__frame" data-reveal="left">
			<blockquote class="motto__quote">
				<p>"Jokainen pinta maalataan kuin se olisi oma."</p>
			</blockquote>
			<div class="motto__attribution">
				<span class="motto__line"></span>
				<span class="motto__name">Maalitykki</span>
			</div>
		</div>
	</div>
</section>

<style>
	.motto {
		background: var(--color-bg);
		padding-block: clamp(4rem, 8vw, 7rem);
	}

	.motto__frame {
		border-left: 4px solid var(--color-accent);
		padding: clamp(2.5rem, 6vw, 4rem);
		text-align: left;
	}

	.motto__quote p {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 3.5vw, 2.5rem);
		font-weight: 700;
		font-style: italic;
		letter-spacing: -0.025em;
		line-height: 1.28;
		color: var(--color-text);
		max-width: 680px;
	}

	.motto__attribution {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 2rem;
	}

	.motto__line {
		display: block;
		width: 2rem;
		height: 2px;
		background: var(--color-accent);
		border-radius: 1px;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 1.4s cubic-bezier(0.215, 0.61, 0.355, 1) 0.5s;
	}

	.motto__frame.revealed .motto__line {
		transform: scaleX(1);
	}

	.motto__name {
		font-size: 0.85rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-text-muted);
	}
</style>
