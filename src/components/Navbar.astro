---
const navLinks = [
	{ label: 'Palvelumme', href: '#palvelut' },
	{ label: 'Kokemuksia', href: '#kokemuksia' },
	{ label: 'Tietoa meistä', href: '#tietoa' },
	{ label: 'Yhteystiedot', href: '#yhteystiedot' },
];
---

<header class="navbar" id="navbar">
	<div class="container navbar__inner">
		<a href="/" class="navbar__logo">
			<img src="/maalitykki2.png" alt="Maalitykki" class="navbar__logo-img navbar__logo-default" />
			<img src="/maalitykki1.png" alt="Maalitykki" class="navbar__logo-img navbar__logo-scrolled" />
		</a>

		<nav class="navbar__nav">
			<ul class="navbar__links">
				{navLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</nav>

		<div class="navbar__right">
			<a href="tel:+358401234567" class="navbar__phone">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
				<span>040 123 4567</span>
			</a>
			<a href="#yhteystiedot" class="navbar__cta">Pyydä tarjous</a>
		</div>

		<button class="navbar__mobile-toggle" aria-label="Avaa valikko" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>

	<div class="navbar__mobile-menu" aria-hidden="true">
		<ul>
			{navLinks.map((link) => (
				<li><a href={link.href}>{link.label}</a></li>
			))}
		</ul>
		<div class="navbar__mobile-actions">
			<a href="tel:+358401234567" class="navbar__mobile-phone">040 123 4567</a>
			<a href="#yhteystiedot" class="navbar__cta navbar__cta--mobile">Pyydä tarjous</a>
		</div>
	</div>
</header>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(18, 19, 24, 0.25);
		backdrop-filter: blur(8px) saturate(140%);
		border-bottom: 1px solid transparent;
		transition: border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
	}

	.navbar.scrolled {
		background: rgba(253, 253, 251, 0.95);
		border-bottom-color: var(--color-border);
		box-shadow: 0 8px 22px rgba(13, 16, 24, 0.08);
	}

	.navbar__inner {
		display: flex;
		align-items: center;
		height: 80px;
		gap: 2rem;
		transition: height 0.3s ease;
	}

	.navbar.scrolled .navbar__inner {
		height: 56px;
	}

	.navbar__logo {
		display: flex;
		align-items: center;
		flex-shrink: 0;
		height: 100%;
		padding-block: 6px;
	}

	.navbar__logo-img {
		height: 100%;
		width: auto;
		transition: opacity 0.3s ease;
	}

	/* Default: show maalitykki2, hide maalitykki1 */
	.navbar__logo-scrolled {
		display: none;
	}

	/* On scroll: show maalitykki1, hide maalitykki2 */
	.navbar.scrolled .navbar__logo-default {
		display: none;
	}

	.navbar.scrolled .navbar__logo-scrolled {
		display: block;
	}

	.navbar__nav {
		flex: 1;
		display: flex;
		justify-content: center;
	}

	.navbar__links {
		display: flex;
		list-style: none;
		gap: 2.25rem;
	}

	.navbar__links a {
		font-size: 0.9rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.86);
		transition: color 0.2s ease;
		letter-spacing: 0.01em;
		white-space: nowrap;
	}

	.navbar.scrolled .navbar__links a {
		color: var(--color-text);
	}

	.navbar__links a:hover {
		color: var(--color-accent);
	}

	.navbar__right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-shrink: 0;
	}

	.navbar__phone {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: #f7f7f5;
		white-space: nowrap;
		transition: color 0.2s ease;
	}

	.navbar.scrolled .navbar__phone {
		color: var(--color-accent);
	}

	.navbar__phone:hover {
		color: var(--color-accent-hover);
	}

	.navbar__phone svg {
		flex-shrink: 0;
	}

	.navbar__cta {
		display: inline-flex;
		align-items: center;
		padding: 0.65rem 1.5rem;
		background: rgba(255, 255, 255, 0.13);
		border: 1px solid rgba(255, 255, 255, 0.35);
		color: white;
		font-size: 0.875rem;
		font-weight: 600;
		border-radius: 4px;
		white-space: nowrap;
		transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}

	.navbar.scrolled .navbar__cta {
		background: var(--color-accent);
		border-color: transparent;
	}

	.navbar__cta:hover {
		background: var(--color-accent-hover);
		transform: translateY(-1px);
	}

	.navbar__mobile-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		width: 32px;
		height: 32px;
		margin-left: auto;
	}

	.navbar__mobile-toggle span {
		display: block;
		width: 22px;
		height: 2px;
		background: #ffffff;
		border-radius: 1px;
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	.navbar.scrolled .navbar__mobile-toggle span {
		background: var(--color-text);
	}

	.navbar__mobile-toggle[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.navbar__mobile-toggle[aria-expanded="true"] span:nth-child(2) {
		opacity: 0;
	}
	.navbar__mobile-toggle[aria-expanded="true"] span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.navbar__mobile-menu {
		display: none;
		padding: 1.5rem var(--container-padding) 2rem;
		background: rgba(253, 253, 251, 0.98);
		backdrop-filter: blur(10px);
		border-top: 1px solid var(--color-border);
	}

	.navbar__mobile-menu[aria-hidden="false"] {
		display: block;
	}

	.navbar__mobile-menu ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.navbar__mobile-menu a {
		display: block;
		padding: 0.75rem 0;
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text);
	}

	.navbar__mobile-actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.25rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--color-border);
	}

	.navbar__mobile-phone {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-accent);
	}

	.navbar__cta--mobile {
		text-align: center;
		justify-content: center;
		padding: 0.85rem 1.5rem;
	}

	@media (max-width: 900px) {
		.navbar__nav,
		.navbar__right {
			display: none;
		}

		.navbar__mobile-toggle {
			display: flex;
		}
	}
</style>

<script>
	const navbar = document.getElementById('navbar');

	window.addEventListener('scroll', () => {
		if (window.scrollY > 10) {
			navbar?.classList.add('scrolled');
		} else {
			navbar?.classList.remove('scrolled');
		}
	});

	const toggle = document.querySelector('.navbar__mobile-toggle');
	const mobileMenu = document.querySelector('.navbar__mobile-menu');

	toggle?.addEventListener('click', () => {
		const expanded = toggle.getAttribute('aria-expanded') === 'true';
		toggle.setAttribute('aria-expanded', String(!expanded));
		mobileMenu?.setAttribute('aria-hidden', String(expanded));
	});

	mobileMenu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			toggle?.setAttribute('aria-expanded', 'false');
			mobileMenu?.setAttribute('aria-hidden', 'true');
		});
	});
</script>
